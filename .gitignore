# Run state is a per-job message bus, never committed. Keep the dirs, drop the
# contents. The !.agent-guild/state/**/ line re-includes directories so the .gitkeep
# negations below can take effect (git won't re-include a file whose parent
# dir is still excluded).
.agent-guild/state/**
!.agent-guild/state/**/
!.agent-guild/state/**/.gitkeep

# check-a11y self-bootstraps these on first run; they're heavy and host-specific.
.agent-guild/scripts/node_modules/
.agent-guild/scripts/package-lock.json

# The audition log is the one piece of state we DO track—it accumulates across jobs.
!.claude/skills/audition/results/results.jsonl

__pycache__/
*.pyc

.DS_Store

# Local-only active context (working-memory-kit)
_working-memory/activeContext.md

